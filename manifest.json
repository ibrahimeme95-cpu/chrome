{
  "manifest_version": 3,
  "name": "PTC Autofill Extension",
  "version": "1.0",
  "description": "Autofill Eightfold AI job application forms",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://ptc.eightfold.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Autofill Form"
  },
  "content_scripts": [
    {
      "matches": ["https://ptc.eightfold.ai/*"],
      "js": ["content.js"]
    }
  ]
}